{
  "name": "smart-puc",
  "version": "3.1.0",
  "description": "Blockchain-based multi-pollutant vehicle emission monitoring and compliance system (BSVI) with OBD-II integration, ML fraud detection, GreenToken rewards, Merkle batching, and UUPS upgradeable contracts. Research prototype accompanying an academic paper.",
  "main": "hardhat.config.js",
  "scripts": {
    "compile": "hardhat compile && node scripts/flatten_artifacts.js",
    "postcompile": "node scripts/flatten_artifacts.js",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "deploy:hardhat": "hardhat run scripts/deploy.js --network hardhat",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:amoy": "hardhat run scripts/deploy.js --network amoy",
    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "deploy:zkevm": "hardhat run scripts/deploy.js --network zkevm",
    "deploy:zkevm_cardona": "hardhat run scripts/deploy.js --network zkevm_cardona",
    "deploy:arbitrum": "hardhat run scripts/deploy.js --network arbitrum",
    "deploy:arbitrum_sepolia": "hardhat run scripts/deploy.js --network arbitrum_sepolia",
    "test": "hardhat test",
    "test:gas": "REPORT_GAS=true hardhat test",
    "test:python": "python -m pytest tests/ -v",
    "measure-gas": "hardhat run scripts/measure_gas.js --network localhost",
    "node": "hardhat node --port 7545",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python -m uvicorn main:app --host 0.0.0.0 --port 5000 --reload",
    "dev:frontend": "http-server frontend -p 3000 -c-1 --cors",
    "dev:obd": "python -m obd_node.obd_device --count 50 --interval 3",
    "start": "npm run docker:up",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "lint:py": "flake8 backend/ ml/ physics/ integrations/ --max-line-length=120 --ignore=E501,W503,E402"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "polygon",
    "hardhat",
    "upgradeable",
    "uups",
    "emission",
    "puc",
    "smart-contract",
    "web3",
    "bsvi",
    "wltc",
    "vsp",
    "fraud-detection",
    "merkle",
    "nft"
  ],
  "author": "Smart PUC Team",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/hardhat-upgrades": "^3.2.1",
    "chai": "^4.3.10",
    "ethers": "^6.13.4",
    "hardhat": "^2.22.15",
    "hardhat-gas-reporter": "^1.0.10",
    "http-server": "^14.1.1",
    "solhint": "^5.0.3",
    "solidity-coverage": "^0.8.12"
  }
}
