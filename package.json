{
  "name": "smart-puc",
  "version": "2.0.0",
  "description": "Blockchain-Based Multi-Pollutant Vehicle Emission Monitoring and Compliance System (BSVI)",
  "main": "truffle-config.js",
  "scripts": {
    "compile": "truffle compile",
    "migrate": "truffle migrate",
    "migrate:sepolia": "truffle migrate --network sepolia",
    "test": "truffle test",
    "test:python": "cd .. && python -m pytest tests/ -v",
    "dev:backend": "cd backend && python app.py",
    "dev:frontend": "npx http-server frontend -p 8080 -c-1 --cors"
  },
  "keywords": [
    "blockchain",
    "ethereum",
    "emission",
    "puc",
    "smart-contract",
    "web3",
    "bsvi",
    "wltc",
    "vsp",
    "fraud-detection",
    "nft"
  ],
  "author": "Smart PUC Team",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "@truffle/hdwallet-provider": "^2.1.15",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "http-server": "^14.1.1"
  }
}
