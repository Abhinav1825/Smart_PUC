# ─────────────────────────────────────────────────────────────────────────
# Smart PUC — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────
#
# COPY this file to `.env` and fill in the values for your deployment.
# NEVER commit the real `.env` — it is in `.gitignore`.
#
# Every variable below is read by the codebase. Grep for os.getenv or
# process.env before adding new entries here — unused keys are dead
# weight and breed confusion.
#
# SECURITY NOTES
# ──────────────
# • The two private keys below MUST NOT be reused across deployments.
# • For local development, use the printed private keys from Ganache
#   (`ganache --deterministic`) or Hardhat node.
# • For production, generate fresh keys and store them in a secret manager
#   (AWS Secrets Manager, Vault, Azure Key Vault). The OBD device key
#   should ideally live in a secure element (ATECC608A, TPM 2.0, ARM
#   TrustZone) — see docs/THREAT_MODEL.md §5.7.
# • NEVER paste a mainnet key with real value into this file.
# ─────────────────────────────────────────────────────────────────────────


# ─── Blockchain RPC ──────────────────────────────────────────────────────
# JSON-RPC endpoint of the chain you are targeting. Ganache default is
# :7545; a stock `npx hardhat node` listens on :8545.
RPC_URL=http://127.0.0.1:7545

# Live chain id. Only consulted by obd_node/obd_device.py (for its EIP-712
# domain) and by hardhat.config.js `localhost` network when you want to
# override the default 5777 (Ganache) to e.g. 31337 (Hardhat).
CHAIN_ID=5777


# ─── Testing-station signer (Node 2) ─────────────────────────────────────
# Hot key that signs on-chain transactions from the FastAPI backend.
# Leave blank to fall back to an unlocked node account via STATION_ADDRESS.
PRIVATE_KEY=

# Alternative to PRIVATE_KEY: if the RPC node has unlocked test accounts
# (Ganache / Hardhat node / Anvil), set this to the address of the
# station that has been registered via `setTestingStation`. Ignored when
# PRIVATE_KEY is set.
STATION_ADDRESS=


# ─── OBD device signer (Node 1) ──────────────────────────────────────────
# Key used by obd_node/obd_device.py to EIP-712 sign telemetry. In
# production this must live inside a secure element.
OBD_DEVICE_PRIVATE_KEY=

# Dev-mode auto-signer used by the backend's /api/record endpoint when a
# client (e.g. the frontend "simulate" button) POSTs a reading without a
# device signature. Pick EXACTLY ONE of the two variables below:
#
#   STATION_DEVICE_PRIVATE_KEY — a local hex private key, or
#   STATION_DEVICE_ADDRESS     — an unlocked node account; the backend
#                                 signs via JSON-RPC eth_signTypedData_v4.
#
# Whichever you pick, the resulting device address MUST already be
# registered on-chain via EmissionRegistry.setRegisteredDevice. Leave
# BOTH blank in production — real submissions must be signed client-side.
STATION_DEVICE_PRIVATE_KEY=
STATION_DEVICE_ADDRESS=

# EIP-712 domain binding for OBD-device signatures. Must match the
# values baked into EmissionRegistry (SmartPUC / 3.2) and the deployed
# proxy address on the target chain.
REGISTRY_ADDRESS=
EIP712_DOMAIN_NAME=SmartPUC
EIP712_DOMAIN_VERSION=3.2


# ─── OBD node → Station link ─────────────────────────────────────────────
# URL the OBD device simulator posts signed readings to. Used only by
# obd_node/obd_device.py (and the bench_latency/bench_throughput helpers).
STATION_URL=http://127.0.0.1:5000


# ─── FastAPI backend: CORS & persistence ─────────────────────────────────
# Comma-separated list of allowed origins. Use explicit domains in prod.
# Set to "*" to allow any origin (dev only).
CORS_ORIGINS=http://localhost:3000

# Path to the SQLite persistence store (audit log, rate-limit counters,
# durable notifications). Leave blank to run in ephemeral in-memory mode.
PERSISTENCE_DB=backend/data/smartpuc.db


# ─── Authentication ──────────────────────────────────────────────────────
# All four values below MUST be set to non-default values before serving
# production traffic. The authority dashboard endpoints refuse to accept
# logins when AUTH_USERNAME / AUTH_PASSWORD are empty.

# HMAC API key protecting device-write endpoints (POST /api/record,
# POST /api/obd/read). Clients send it as the X-API-Key header.
API_KEY=

# JWT signing secret for the authority dashboard — use at least 32 bytes
# of random data. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Authority dashboard login (served at POST /api/auth/login).
AUTH_USERNAME=
AUTH_PASSWORD=


# ─── Rate limiting ───────────────────────────────────────────────────────
# Max requests per IP per 60-second window across all endpoints. The
# limiter is in-memory unless PERSISTENCE_DB is set.
RATE_LIMIT_MAX=120


# ─── Simulator defaults ──────────────────────────────────────────────────
# Default vehicle ID used by the simulator and smoke tests when the
# request body does not supply one.
DEFAULT_VEHICLE_ID=MH12AB1234

# Driving cycle to simulate when the backend starts with no explicit
# cycle= argument. Leave blank to pick automatically based on
# STATION_COUNTRY below (IN → MIDC, else WLTC). Set explicitly to "wltc"
# or "midc" to override.
SMART_PUC_DEFAULT_CYCLE=

# Testing-station country code. The only value that is interpreted today
# is "IN", which switches the simulator to the Modified Indian Driving
# Cycle (MIDC, 1180 s, per ARAI-IS 14272 / AIS-137) instead of the
# European WLTC 1800 s reconstruction. Closes audit 13A #10.
STATION_COUNTRY=IN


# ─── Chain event projection (phase_listener) ────────────────────────────
# SQLite file used by backend/phase_listener.py to project
# PhaseCompleted + BatchRootCommitted events into queryable rows. Closes
# audit Fix #10. Default is data/chain_events.db under the repo root.
PHASE_LISTENER_DB=data/chain_events.db


# ─── Testnet / mainnet deployment (hardhat.config.js) ────────────────────
# HD wallet mnemonic used by Hardhat when targeting sepolia / polygon /
# amoy / zkevm / arbitrum networks. NEVER reuse a mnemonic that holds
# real funds on mainnet.
MNEMONIC=

# Infura project ID used by the same remote networks above.
INFURA_PROJECT_ID=


# ─── Gas benchmarking (optional dev) ─────────────────────────────────────
# Set REPORT_GAS=true to enable hardhat-gas-reporter during `npx hardhat
# test`. GAS_REPORT_OUTPUT optionally redirects the report to a file.
# REPORT_GAS=
# GAS_REPORT_OUTPUT=
