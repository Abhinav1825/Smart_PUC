# ================================================================
# Smart PUC — Environment Variables
# ================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================================

# ─── Blockchain RPC ────────────────────────────────────────
# Ganache (local):  http://127.0.0.1:7545
# Sepolia (testnet): https://sepolia.infura.io/v3/YOUR_PROJECT_ID
RPC_URL=http://127.0.0.1:7545

# ─── Wallet ────────────────────────────────────────────────
# Private key from Ganache Account 0 (deterministic mode)
# Get from Ganache GUI or use the deterministic key below
PRIVATE_KEY=0x4f3edf983ac636a65a842ce7c78d9aa706d3b113bce9c46f30d7d21715b23b1d

# Mnemonic for Truffle HDWalletProvider (Sepolia deployment only)
MNEMONIC=your twelve word mnemonic phrase here for sepolia deployment only

# ─── Infura / Alchemy ─────────────────────────────────────
# Required only for Sepolia testnet deployment
INFURA_PROJECT_ID=your_infura_project_id_here

# ─── Contract ─────────────────────────────────────────────
# Auto-detected from Truffle build, but can override here
# CONTRACT_ADDRESS=0xYourDeployedContractAddress

# ─── Flask Backend ────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=true

# ─── Vehicle ──────────────────────────────────────────────
DEFAULT_VEHICLE_ID=MH12AB1234

# ─── Security ─────────────────────────────────────────────
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8080,http://localhost:8080

# Rate limiting (requests per minute per IP)
RATE_LIMIT_MAX=120
