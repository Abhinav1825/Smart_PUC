# ─────────────────────────────────────────────────────────────────────────
# Smart PUC — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────
#
# COPY this file to `.env` and fill in the values for your deployment.
# NEVER commit the real `.env` file — it is in `.gitignore`.
#
# SECURITY NOTES
# ──────────────
# • The two private keys below MUST NOT be reused across deployments.
# • For local development, paste one of Ganache's printed private keys
#   (run with --deterministic to get a stable set).
# • For production, generate fresh keys and store them in a secret manager
#   (AWS Secrets Manager, Hashicorp Vault, Azure Key Vault) or — preferably
#   for the OBD device key — in a hardware secure element (ATECC608A,
#   TPM 2.0, ARM TrustZone). See docs/THREAT_MODEL.md §5.7.
# • NEVER paste a mainnet key with real value into this file.
# ─────────────────────────────────────────────────────────────────────────


# ─── Blockchain ──────────────────────────────────────────────────────────

# JSON-RPC endpoint of the chain you are targeting.
RPC_URL=http://127.0.0.1:7545

# Testing-station hot key (Node 2). Signs on-chain transactions.
# Leave blank here; set in your real .env only.
PRIVATE_KEY=

# OBD device key (Node 1). Used to sign telemetry with ECDSA.
# In production this should live inside a secure element (see THREAT_MODEL.md).
OBD_DEVICE_PRIVATE_KEY=


# ─── Flask Backend ───────────────────────────────────────────────────────

FLASK_PORT=5000
FLASK_DEBUG=false
# Comma-separated list of allowed origins. Use explicit domains in prod.
CORS_ORIGINS=http://localhost:3000


# ─── Authentication ──────────────────────────────────────────────────────
# All four values below MUST be set to non-default values before serving
# production traffic. The backend refuses to start the authority endpoints
# if AUTH_USERNAME / AUTH_PASSWORD are empty.

# HMAC API key protecting OBD write endpoints (POST /api/record).
API_KEY=

# JWT signing secret — use at least 32 bytes of random data.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=

# Authority dashboard login. No default is provided — you must set these.
AUTH_USERNAME=
AUTH_PASSWORD=


# ─── Rate Limiting ───────────────────────────────────────────────────────

# Max requests per IP per 60-second window.
RATE_LIMIT_MAX=120

# Persistence path for the rate-limit store + audit log (SQLite).
# Leave blank to disable persistence (ephemeral in-memory mode).
PERSISTENCE_DB=backend/data/smartpuc.db


# ─── Vehicle ─────────────────────────────────────────────────────────────

# Default vehicle ID for simulator and smoke tests.
DEFAULT_VEHICLE_ID=MH12AB1234


# ─── Testnet / Mainnet Deployment ────────────────────────────────────────

# HD wallet mnemonic for Truffle HDWalletProvider.
# NEVER reuse a mnemonic that holds real funds on mainnet.
MNEMONIC=

# Infura project ID (Sepolia, Polygon, zkEVM, Arbitrum).
INFURA_PROJECT_ID=


# ─── IPFS (optional) ─────────────────────────────────────────────────────

# Gateway used by the frontend to resolve certificate metadata.
IPFS_GATEWAY=https://ipfs.io/ipfs/


# ─── VAHAN Integration (optional) ────────────────────────────────────────
# Leave blank to use the built-in MockVaahanService.
# See integrations/vaahan_bridge.py for the expected API shape.
VAHAN_API_BASE=
VAHAN_API_KEY=
