# ═══════════════════════════════════════════════════════════
# Smart PUC — Environment Variables Template
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════

# ─── Blockchain RPC ─────────────────────────────────────────
# Ganache (local): http://127.0.0.1:7545
# Sepolia (testnet): https://sepolia.infura.io/v3/YOUR_PROJECT_ID
RPC_URL=http://127.0.0.1:7545

# ─── Wallet ─────────────────────────────────────────────────
# Private key from Ganache (Account 0) — for backend tx signing
# Get from Ganache GUI → click key icon on any account
PRIVATE_KEY=your_ganache_private_key_here

# Mnemonic for Truffle HDWalletProvider (Sepolia deployment)
MNEMONIC=your twelve word mnemonic phrase here for sepolia deployment only

# ─── Infura / Alchemy ──────────────────────────────────────
# Required for Sepolia testnet deployment
INFURA_PROJECT_ID=your_infura_project_id_here

# ─── Contract ──────────────────────────────────────────────
# Auto-detected from Truffle build, but can override here
# CONTRACT_ADDRESS=0xYourDeployedContractAddress

# ─── Flask ─────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=true

# ─── Vehicle ───────────────────────────────────────────────
DEFAULT_VEHICLE_ID=MH12AB1234
